generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum Role {
  recruiter
  applicant
}

enum Industry {
  EdTech
  FinTech
  HealthTech
  SaaS
  ECommerce
  Gaming
  Logistics
  RealEstate
  CyberSecurity
  Consulting
  Manufacturing
  Media
  Travel
  AI
  Other
}

enum Experience {
  Fresher
  OneToTwoYears
  TwoToThreeYears
  ThreeToFiveYears
  FiveToSevenYears
  SevenPlusYears
}

enum Status {
  Student
  SeachingForJob
  WorkingProfessional
}

enum JobPreferences {
  SoftwareEngineer
  WebDeveloper
  DataAnalyst
  DataScientist
  UIUXDesigner
  VideoEditor
  Sales
  Marketing
  ProductManager
  QAEngineer
  DevOpsEngineer
  BusinessAnalyst
  ContentWriter
  HR
  CustomerSupport
  Operations
  Other
}

enum ApplicationStatus {
  Applied
  Accepted
  Rejected
}

enum JobStatus {
  Open
  Closed
}

enum WorkStatus {
  Remote
  Offline
}

enum SparkPostingStatus {
  Published
  Archived
  Closed
}

enum SparkApplicationStatus {
  ProfileStarted
  Applied
  RecruiterApproved
  InterviewInvited
  InterviewStarted
  InterviewCompleted
  RecruiterReview
  Vetted
  Declined
}

model User {
  id               String            @id @default(uuid())
  firstName        String
  lastName         String
  email            String            @unique
  role             Role              @default(applicant)
  password         String
  image            String?
  createdAt        DateTime          @default(now())
  recruiterProfile RecruiterProfile?
  applicantProfile ApplicantProfile?
  jobsCreated      Job[]
  applications     Application[]
}

model RecruiterProfile {
  id              String   @id @default(uuid())
  user            User     @relation(fields: [userId], references: [id])
  userId          String   @unique
  companyName     String
  companyWebsite  String?
  industry        Industry
  position        String?
  linkedInProfile String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model ApplicantProfile {
  id              String           @id @default(uuid())
  user            User             @relation(fields: [userId], references: [id])
  userId          String           @unique
  phone           String
  age             Int
  education       String // B.E., B.Tech, etc.
  instituteName   String
  currentCompany  String?
  currentStatus   Status
  experience      Experience
  jobPreferences  JobPreferences[]
  linkedInProfile String?
  xProfile        String?
  githubProfile   String?
  city            String
  state           String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
}

model Job {
  id             String        @id @default(uuid())
  title          String
  description    String
  location       String
  experience     Experience
  salary         String
  requiredSkills String[]
  workStatus     WorkStatus
  status         JobStatus     @default(Open)
  createdById    String
  createdBy      User          @relation(fields: [createdById], references: [id])
  applications   Application[]
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt
}

model Application {
  id            String            @id @default(uuid())
  status        ApplicationStatus @default(Applied)
  jobId         String
  job           Job               @relation(fields: [jobId], references: [id])
  applicantId   String
  applicant     User              @relation(fields: [applicantId], references: [id])
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  InterviewInfo InterviewInfo?
  feedback      Feedback?
  analysis      Analysis?
  overallScore  Int?
}

model InterviewInfo {
  id            String      @id @default(uuid())
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String      @unique
  resumeSummary String
  qnas          QnA[]
  createdAt     DateTime    @default(now())
  startTime     DateTime?
}

model QnA {
  id              String        @id @default(uuid())
  interviewInfo   InterviewInfo @relation(fields: [interviewInfoId], references: [id])
  interviewInfoId String
  question        String
  answer          String
  createdAt       DateTime      @default(now())
}

model Feedback {
  id            String      @id @default(uuid())
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String      @unique
  strengths     String[]
  improvements  String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model Analysis {
  id            String      @id @default(uuid())
  application   Application @relation(fields: [applicationId], references: [id])
  applicationId String      @unique
  aiAnalysis    String[]
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
}

model SparkJobPosting {
  id               String             @id @default(uuid())
  sourceSystem     String             @default("staffingnation")
  sourceEntityType String             @default("job_description")
  sourceEntityId   String             @unique
  sourceRevision   String?
  payloadVersion   String
  clientId         String
  clientName       String?
  title            String
  slug             String             @unique
  overview         String?
  responsibilities String?
  requirements     String?
  qualifications   String?
  skills           String[]           @default([])
  certifications   String[]           @default([])
  physicalRequirements Json           @default("{}")
  payRangeMin      Decimal?
  payRangeMax      Decimal?
  currency         String             @default("USD")
  country          Json?
  socCode          String?
  socTitle         String?
  wcCode           String?
  wcDescription    String?
  publicJobsBaseUrl String            @default("https://tcwtable.com/jobs")
  publicUrl        String?
  status           SparkPostingStatus @default(Published)
  rawPayload       Json
  publishedAt      DateTime           @default(now())
  lastSyncedAt     DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  applications     SparkApplication[]
}

model SparkCandidateProfile {
  id                       String             @id @default(uuid())
  email                    String             @unique
  firstName                String?
  lastName                 String?
  phone                    String?
  city                     String?
  state                    String?
  country                  String?
  resumeUrl                String?
  profileData              Json               @default("{}")
  geolocationConsentAt     DateTime?
  aiInterviewConsentAt     DateTime?
  recordingConsentAt       DateTime?
  fraudReviewData          Json               @default("{}")
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  applications             SparkApplication[]
}

model SparkApplication {
  id                  String                 @id @default(uuid())
  posting             SparkJobPosting        @relation(fields: [postingId], references: [id])
  postingId           String
  candidate           SparkCandidateProfile? @relation(fields: [candidateId], references: [id])
  candidateId         String?
  candidateEmail      String?
  candidateName       String?
  candidatePhone      String?
  status              SparkApplicationStatus @default(ProfileStarted)
  recruiterNotes      String?
  communicationState  Json                   @default("{}")
  deviceSignals       Json                   @default("{}")
  locationSignals     Json                   @default("{}")
  interviewMedia      Json                   @default("{}")
  interviewTranscript Json                   @default("{}")
  aiSummary           Json                   @default("{}")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([postingId, status])
  @@index([candidateEmail])
}
