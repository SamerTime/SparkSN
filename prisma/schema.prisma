generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum SparkPostingStatus {
  Published
  Archived
  Closed
}

enum SparkApplicationStatus {
  ProfileStarted
  Applied
  RecruiterApproved
  InterviewInvited
  InterviewStarted
  InterviewCompleted
  RecruiterReview
  Vetted
  Declined
}

model SparkJobPosting {
  id               String             @id @default(uuid())
  sourceSystem     String             @default("staffingnation")
  sourceEntityType String             @default("job_description")
  sourceEntityId   String             @unique
  sourceRevision   String?
  payloadVersion   String
  clientId         String
  clientName       String?
  title            String
  slug             String             @unique
  overview         String?
  responsibilities String?
  requirements     String?
  qualifications   String?
  skills           String[]           @default([])
  certifications   String[]           @default([])
  physicalRequirements Json           @default("{}")
  payRangeMin      Decimal?
  payRangeMax      Decimal?
  currency         String             @default("USD")
  country          Json?
  socCode          String?
  socTitle         String?
  wcCode           String?
  wcDescription    String?
  publicJobsBaseUrl String            @default("https://tcwtable.com/jobs")
  publicUrl        String?
  status           SparkPostingStatus @default(Published)
  rawPayload       Json
  publishedAt      DateTime           @default(now())
  lastSyncedAt     DateTime           @default(now())
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt
  applications     SparkApplication[]
}

model SparkCandidateProfile {
  id                       String             @id @default(uuid())
  email                    String             @unique
  firstName                String?
  lastName                 String?
  phone                    String?
  city                     String?
  state                    String?
  country                  String?
  resumeUrl                String?
  profileData              Json               @default("{}")
  geolocationConsentAt     DateTime?
  aiInterviewConsentAt     DateTime?
  recordingConsentAt       DateTime?
  fraudReviewData          Json               @default("{}")
  createdAt                DateTime           @default(now())
  updatedAt                DateTime           @updatedAt
  applications             SparkApplication[]
}

model SparkApplication {
  id                  String                 @id @default(uuid())
  posting             SparkJobPosting        @relation(fields: [postingId], references: [id])
  postingId           String
  candidate           SparkCandidateProfile? @relation(fields: [candidateId], references: [id])
  candidateId         String?
  candidateEmail      String?
  candidateName       String?
  candidatePhone      String?
  status              SparkApplicationStatus @default(ProfileStarted)
  recruiterNotes      String?
  communicationState  Json                   @default("{}")
  deviceSignals       Json                   @default("{}")
  locationSignals     Json                   @default("{}")
  interviewMedia      Json                   @default("{}")
  interviewTranscript Json                   @default("{}")
  aiSummary           Json                   @default("{}")
  createdAt           DateTime               @default(now())
  updatedAt           DateTime               @updatedAt

  @@index([postingId, status])
  @@index([candidateEmail])
}
